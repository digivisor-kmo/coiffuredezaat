---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Split from '../components/Split.astro';
import TeamGrid from '../components/TeamGrid.astro';
import site from '../data/site.json';
import team from '../data/team.json';

const homepageTeam = team.filter((l) => l.homepage);
---
<Base
  titel="Kapper Temse | Coiffure De Zaat — duurzaam kapsalon aan de Schelde"
  beschrijving="Kapsalon in Temse met acht specialisten, ammoniakvrije kleuringen en balayage op maat. 4,7★ op Google. Boek online je afspraak bij Coiffure De Zaat."
  actief="/"
  headerModus="overlay"
>
  <Hero
    beeld="/beelden/salon/hero-home-salon.jpg"
    alt="Het salon van Coiffure De Zaat in Temse"
    kicker={`Kapsalon · Georges Van Dammeplein, ${site.adres.gemeente}`}
    titel={site.slogan}
  >
    <a class="knop licht" href={site.boekUrl} target="_blank" rel="noopener">Boek een afspraak</a>
    <a class="hero-link" href="/diensten-prijzen">Diensten &amp; prijzen&ensp;→</a>
  </Hero>

  <section>
    <div class="kader"><div class="smal" data-reveal>
      <span class="accentlijn" aria-hidden="true"></span>
      <p class="serif statement">
        Haar krijgt hier de tijd die het verdient. Acht specialisten,
        kleur zonder ammoniak, en een stoel die even helemaal van jou is.
      </p>
      <p class="caps subscore">Twintig jaar vakmanschap in {site.adres.gemeente} &middot; {site.reviews.score} op {site.reviews.bron} &middot; {site.reviews.aantal} reviews</p>
    </div></div>
  </section>

  <Split
    beeld="/beelden/salon/dames-haar.png"
    alt="Kleurwerk van Coiffure De Zaat"
    kicker="Kleur & balayage"
    titel="Kleur is ons vak."
  >
    <p>
      Van een subtiele glans tot een volledige transformatie: onze colorists werken
      uitsluitend ammoniakvrij, met La Biosthétique en Aveda. Eerlijk advies over
      wat jouw haar aankan, vooraf.
    </p>
    <a slot="actie" class="knop" href="/kleuren-balayage">Ontdek ons kleurwerk</a>
  </Split>

  <Split
    beeld="/beelden/salon/heren-manscorner.jpg"
    alt="The Manscorner, de barbierhoek van De Zaat"
    kicker="The Manscorner"
    titel="Heren & barbier."
    beeldRechts
  >
    <p>
      Klassieke snit, old-school scheerbeurt of baardtrim — in een hoek van het salon
      die helemaal van de heren is. Snit vanaf € 32, op afspraak.
    </p>
    <a slot="actie" class="knop" href="/diensten-prijzen#heren">Bekijk het menu</a>
  </Split>

  <section class="donker">
    <div class="kader"><div class="smal" data-reveal>
      <p class="kwoot serif">“Dankuwel om mij terug goed als vrouw te laten voelen.”</p>
      <p class="caps bron">Maria — juni 2026, na haar kleurbehandeling</p>
    </div></div>
  </section>

  <section>
    <div class="kader">
      <div class="sectiekop" data-reveal>
        <span class="caps">Het team</span>
        <h2 class="serif">Boek bij wie bij jou past.</h2>
      </div>
      <TeamGrid leden={homepageTeam} />
      <div class="centreer" data-reveal><a class="knop" href="/team">Het volledige team</a></div>
    </div>
  </section>

  <section class="bezoek">
    <div class="kader bezoekgrid">
      <div class="bezoek-intro" data-reveal>
        <span class="accentlijn linksop" aria-hidden="true"></span>
        <span class="caps bezoek-kicker">Bezoek</span>
        <h2 class="serif bezoek-titel">Kom even<br />tot rust.</h2>
        <p class="bezoek-adres">
          {site.adres.straat}, {site.adres.postcode} {site.adres.gemeente}<br />
          <span class="stil">Gratis parkeren op het plein, vlak bij de Temsebrug.</span>
        </p>
        <div class="bezoek-acties">
          <a class="knop" href={site.boekUrl} target="_blank" rel="noopener">Boek een afspraak</a>
          <a class="tekstlink" href={`tel:${site.telefoonLink}`}>{site.telefoon}</a>
        </div>
      </div>
      <div class="bezoek-uren" data-reveal="150">
        {site.uren.map((u) => (
          <div class="uur-rij">
            <span class="dag">{u.dag}</span>
            <span class="tijd serif">{u.tijd}</span>
          </div>
        ))}
        <p class="stil feestdag">{site.feestdagNoot}</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .subscore { color: var(--kleur-grijs); margin-top: 34px; }
  .centreer { text-align: center; margin-top: 58px; }

  /* ---- bezoek: warm klei-blok, uren als typografisch menu ---- */
  .bezoek { background: var(--kleur-klei); }
  .bezoekgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 8vw; align-items: center; }
  .bezoek-kicker { color: var(--kleur-grijs); display: block; margin-bottom: 16px; }
  .bezoek-titel { font-size: clamp(30px, 3.4vw, 46px); margin-bottom: 26px; }
  .bezoek-adres { color: var(--kleur-grijs); }
  .stil { font-size: 13px; color: var(--kleur-grijs); }
  .bezoek-acties { margin-top: 34px; display: flex; gap: 26px; align-items: center; flex-wrap: wrap; }
  .uur-rij { display: flex; justify-content: space-between; align-items: baseline; gap: 24px; padding: 17px 0; border-bottom: 1px solid rgba(25,24,23,.14); }
  .uur-rij:first-child { border-top: 1px solid rgba(25,24,23,.14); }
  .dag { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; }
  .tijd { font-size: 17px; }
  .feestdag { margin-top: 16px; }
  @media (max-width: 960px) { .bezoekgrid { grid-template-columns: 1fr; gap: 44px; } }
</style>
