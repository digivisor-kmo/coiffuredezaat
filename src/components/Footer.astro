---
import site from '../data/site.json';
---
<footer>
  <div class="kader fgrid" data-reveal>
    <div>
      <img class="flogo" src="/beelden/logo-wit.png" alt={site.naam} width="230" height="69" />
      {site.adres.straat}<br />{site.adres.postcode} {site.adres.gemeente}<br />
      <a href={`tel:${site.telefoonLink}`}>{site.telefoon}</a><br />
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </div>
    <div>
      <span class="caps">Salon</span>
      <a href="/diensten-prijzen">Diensten &amp; prijzen</a>
      <a href="/kleuren-balayage">Kleur &amp; balayage</a>
      <a href="/team">Team</a>
      <a href="/bruiden">Bruiden</a>
    </div>
    <div>
      <span class="caps">Praktisch</span>
      <a href="/contact">Contact &amp; uren</a>
      <a href={site.boekUrl} target="_blank" rel="noopener">Online boeken</a>
      <a href="/over">Over De Zaat</a>
    </div>
    <div>
      <span class="caps">Volg ons</span>
      <a href={site.socials.instagram} target="_blank" rel="noopener">Instagram</a>
      <a href={site.socials.facebook} target="_blank" rel="noopener">Facebook</a>
    </div>
  </div>
  <div class="kader onder">
    <span>© {new Date().getFullYear()} {site.naam}</span>
    <a href="/privacy">Privacy</a>
  </div>
</footer>

<style>
  footer { border-top: 1px solid var(--kleur-lijn); padding: 70px 0 40px; font-size: 13px; color: var(--kleur-grijs); }
  .fgrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .flogo { height: 30px; width: auto; object-fit: contain; filter: brightness(0); opacity: .9; margin-bottom: 18px; }
  footer .caps { color: var(--kleur-inkt); display: block; margin-bottom: 14px; }
  footer a { color: var(--kleur-grijs); text-decoration: none; display: block; padding: 3px 0; }
  footer a:hover { color: var(--kleur-inkt); }
  .onder { display: flex; justify-content: space-between; margin-top: 50px; padding-top: 24px; border-top: 1px solid var(--kleur-lijn); }
  .onder a { display: inline; }
  @media (max-width: 960px) { .fgrid { grid-template-columns: 1fr 1fr; } }
</style>
