---
import site from '../data/site.json';
const { actief = '' } = Astro.props;
const items = [
  { pad: '/diensten-prijzen', label: 'Diensten & prijzen' },
  { pad: '/kleuren-balayage', label: 'Kleur' },
  { pad: '/team', label: 'Team' },
  { pad: '/bruiden', label: 'Bruiden' },
];
---
<header>
  <div class="hgrid">
    <nav class="links" aria-label="Hoofdnavigatie">
      {items.map((i) => (
        <a class="navlink" href={i.pad} aria-current={actief === i.pad ? 'page' : undefined}>{i.label}</a>
      ))}
    </nav>
    <a class="merk" href="/" aria-label={`${site.naam} — home`}>
      <img src="/beelden/logo-wit.png" alt={site.naam} width="230" height="69" />
    </a>
    <div class="hrechts">
      <a class="navlink" href="/contact" aria-current={actief === '/contact' ? 'page' : undefined}>Contact</a>
      <a class="boek" href={site.boekUrl} target="_blank" rel="noopener">Boek een afspraak</a>
    </div>
    <button class="burger" data-menu-knop aria-expanded="false" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>
  <div class="mmenu" data-menu>
    {items.map((i) => <a href={i.pad}>{i.label}</a>)}
    <a href="/contact">Contact</a>
    <a href={site.boekUrl} target="_blank" rel="noopener">Boek een afspraak</a>
  </div>
</header>

<style>
  header { position: sticky; top: 0; z-index: 60; background: rgba(247, 244, 238, .92); backdrop-filter: blur(8px); border-bottom: 1px solid var(--kleur-lijn); }
  .hgrid { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 0 var(--kader-pad); height: 76px; max-width: var(--kader-max); margin: 0 auto; }
  nav.links { display: flex; gap: 30px; }
  .merk { display: flex; justify-content: center; }
  .merk img { height: 34px; width: auto; object-fit: contain; filter: brightness(0); }
  .hrechts { display: flex; justify-content: flex-end; gap: 26px; align-items: center; }
  .boek { font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--kleur-inkt); text-decoration: none; border: 1px solid var(--kleur-inkt); padding: 11px 22px; transition: background .25s ease, color .25s ease; }
  .boek:hover { background: var(--kleur-inkt); color: var(--kleur-been); }
  .burger { display: none; background: none; border: none; cursor: pointer; width: 26px; justify-self: end; }
  .burger span { display: block; height: 1px; background: var(--kleur-inkt); margin: 7px 0; }
  .mmenu { display: none; border-bottom: 1px solid var(--kleur-lijn); background: var(--kleur-been); padding: 26px var(--kader-pad) 34px; }
  .mmenu :global(a), .mmenu a { display: block; font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--kleur-inkt); text-decoration: none; padding: 13px 0; border-bottom: 1px solid var(--kleur-lijn); }
  .mmenu.open { display: block; }
  @media (max-width: 960px) {
    nav.links, .hrechts { display: none; }
    .hgrid { grid-template-columns: auto 1fr auto; }
    .merk { justify-self: start; }
    .burger { display: block; }
  }
</style>
